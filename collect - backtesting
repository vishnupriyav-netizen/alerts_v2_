WITH
ref AS (
    SELECT toDate(now()) AS ref_date        -- change this for backtesting
),
date_spine AS (
    SELECT (SELECT ref_date FROM ref) - number AS check_date
    FROM numbers(10)
),
active_pairs AS (
    SELECT provider, charge_currency
    FROM payin FINAL
    WHERE substr(payin_id, 1, 3) = 'col'
      AND payin_created_at >= (SELECT ref_date FROM ref) - INTERVAL 20 DAY
      AND payin_created_at <  (SELECT ref_date FROM ref) + INTERVAL 1 DAY  -- fixed
      AND lower(seller_email) NOT LIKE '%@tazapay.com'
      AND lower(seller_email) NOT LIKE '%@digitrade.com'
    GROUP BY provider, charge_currency
    HAVING countDistinct(payin_id) > 100
),
daily_traffic AS (
    SELECT
        toDate(payin_created_at)    AS date,
        provider,
        charge_currency,
        countDistinct(payin_id)     AS traffic
    FROM payin FINAL
    WHERE substr(payin_id, 1, 3) = 'col'
      AND payin_created_at >= (SELECT ref_date FROM ref) - INTERVAL 28 DAY
      AND payin_created_at <  (SELECT ref_date FROM ref) + INTERVAL 1 DAY  -- fixed
      AND lower(seller_email) NOT LIKE '%@tazapay.com'
      AND lower(seller_email) NOT LIKE '%@digitrade.com'
    GROUP BY 1, 2, 3
)
SELECT
    d.check_date,
    a.provider,
    a.charge_currency,
    coalesce(curr.traffic, 0)   AS last_24h_traffic,
    coalesce(dow7.traffic, 0)   AS same_dow_last_week_traffic,
    CASE
        WHEN coalesce(curr.traffic, 0) = 0
             AND coalesce(dow7.traffic, 0) > 0
            THEN 'CRITICAL - zero traffic (was active same day last week)'
        ELSE 'OK'
    END                         AS alert_flag

FROM date_spine d
CROSS JOIN active_pairs a
LEFT JOIN daily_traffic curr
    ON  curr.date            = d.check_date
    AND curr.provider        = a.provider
    AND curr.charge_currency = a.charge_currency
LEFT JOIN daily_traffic dow7
    ON  dow7.date            = d.check_date - 7
    AND dow7.provider        = a.provider
    AND dow7.charge_currency = a.charge_currency

ORDER BY alert_flag DESC, d.check_date DESC, a.provider, a.charge_currency
