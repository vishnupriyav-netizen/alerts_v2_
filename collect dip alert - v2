
WITH
active_pairs AS (
    SELECT provider, charge_currency
    FROM payin FINAL
    WHERE substr(payin_id, 1, 3) = 'col'
      AND payin_created_at >= now() - INTERVAL 20 DAY
    -- AND payin_created_at >= '2026-02-17' AND payin_created_at <  '2026-03-09'
      AND lower(seller_email) NOT LIKE '%@tazapay.com'
      AND lower(seller_email) NOT LIKE '%@digitrade.com'
    GROUP BY provider, charge_currency
    HAVING countDistinct(payin_id) > 80
),
last_24h AS (
    SELECT provider, charge_currency, countDistinct(payin_id) AS traffic
    FROM payin FINAL
    WHERE substr(payin_id, 1, 3) = 'col'
    -- AND payin_created_at >= '2026-03-08' AND payin_created_at <  '2026-03-09'
      AND payin_created_at >= now() - INTERVAL 24 HOUR
      AND lower(seller_email) NOT LIKE '%@tazapay.com'
      AND lower(seller_email) NOT LIKE '%@digitrade.com'
    GROUP BY 1, 2
),
prior_24h AS (
    SELECT provider, charge_currency, countDistinct(payin_id) AS traffic
    FROM payin FINAL
    WHERE substr(payin_id, 1, 3) = 'col'
      AND payin_created_at >= now() - INTERVAL 48 HOUR
      AND payin_created_at <  now() - INTERVAL 24 HOUR
      -- AND payin_created_at >= '2026-03-07' AND payin_created_at <  '2026-03-08' 
      AND lower(seller_email) NOT LIKE '%@tazapay.com'
      AND lower(seller_email) NOT LIKE '%@digitrade.com'
    GROUP BY 1, 2
),
-- Same day of week, same 24h window, exactly 7 days ago
same_dow_last_week AS (
    SELECT provider, charge_currency, countDistinct(payin_id) AS traffic
    FROM payin FINAL
    WHERE substr(payin_id, 1, 3) = 'col'
    -- AND payin_created_at >= '2026-03-01' AND payin_created_at <  '2026-03-02'
      AND payin_created_at >= now() - INTERVAL 8 DAY
      AND payin_created_at <  now() - INTERVAL 7 DAY
      AND lower(seller_email) NOT LIKE '%@tazapay.com'
      AND lower(seller_email) NOT LIKE '%@digitrade.com'
      
    GROUP BY 1, 2
),

final as (
SELECT
    a.provider,
    a.charge_currency,
    coalesce(t.traffic, 0)   AS last_24h_traffic,
    coalesce(p.traffic, 0)   AS prior_24h_traffic,
    coalesce(w.traffic, 0)   AS same_dow_last_week_traffic,
    now() AS checked_at,
    -- '2026-03-09 00:00:00' AS checked_at,
    CASE
        -- WHEN coalesce(t.traffic, 0) = 0
        --     AND coalesce(p.traffic, 0) > 0
        --     THEN 'CRITICAL - zero traffic (was active prior 24h)'
        WHEN coalesce(t.traffic, 0) = 0
             AND coalesce(w.traffic, 0) > 0
            THEN 'Alert'
        ELSE null    END                      AS alert_flag

FROM active_pairs a
LEFT JOIN last_24h t         ON a.provider = t.provider AND a.charge_currency = t.charge_currency
LEFT JOIN prior_24h p        ON a.provider = p.provider AND a.charge_currency = p.charge_currency
LEFT JOIN same_dow_last_week w ON a.provider = w.provider AND a.charge_currency = w.charge_currency

-- WHERE coalesce(t.traffic, 0) = 0
--   AND (
--       coalesce(p.traffic, 0) > 0
--       OR coalesce(w.traffic, 0) > 0
--   )

ORDER BY alert_flag, a.provider, a.charge_currency)


select * from final
